{
  "expo": {
    "name": "EntregaX",
    "slug": "entregax-mobile-app",
    "scheme": "entregax",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entregax.mobile",
      "buildNumber": "4",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:www.entregax.app",
        "applinks:entregax.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "EntregaX usa la cámara para escanear guías, códigos QR y tomar fotos de paquetes.",
        "NSPhotoLibraryUsageDescription": "EntregaX accede a tu galería para adjuntar fotos de paquetes o comprobantes.",
        "NSPhotoLibraryAddUsageDescription": "EntregaX guarda guías y comprobantes generados en tu galería.",
        "NSLocationWhenInUseUsageDescription": "EntregaX usa tu ubicación para mostrar la sucursal más cercana y validar entregas.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "EntregaX solo usa tu ubicación cuando la app está abierta; no realiza seguimiento en segundo plano.",
        "NSBluetoothAlwaysUsageDescription": "EntregaX usa Bluetooth para conectar impresoras de guías.",
        "NSBluetoothPeripheralUsageDescription": "EntregaX usa Bluetooth para conectar impresoras térmicas de guías.",
        "NSFaceIDUsageDescription": "EntregaX usa Face ID para que entres más rápido sin escribir tu contraseña.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.195261632917-l736lhaudp3p3lpkrnfv1u21v6hd8g8s"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.entregax.mobile",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "www.entregax.app" },
            { "scheme": "https", "host": "entregax.app" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "EntregaX usa Face ID para que entres más rápido sin escribir tu contraseña."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.entregax.mobile.** { *; }\n-keep class com.facebook.hermes.** { *; }\n-keep class com.facebook.jni.** { *; }"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "EntregaX usa la cámara para escanear guías y tomar fotos de paquetes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "EntregaX accede a tu galería para adjuntar fotos de paquetes.",
          "cameraPermission": "EntregaX usa la cámara para tomar fotos de paquetes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "EntregaX usa tu ubicación para mostrar la sucursal más cercana y validar entregas."
        }
      ],
      "expo-web-browser",
      "expo-video",
      "expo-audio",
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/gong.wav"]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b6043c48-2360-4a21-afa7-3ea091d6c74c"
      },
      "googleIosClientId": "195261632917-l736lhaudp3p3lpkrnfv1u21v6hd8g8s.apps.googleusercontent.com",
      "googleAndroidClientId": "195261632917-ou8b8i8ojui8d2rojdd2ammf3v1p68um.apps.googleusercontent.com",
      "googleWebClientId": "195261632917-6423vo6huqh0p5dd6itj5igs53sdqlfi.apps.googleusercontent.com"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/b6043c48-2360-4a21-afa7-3ea091d6c74c",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "aldozaia"
  }
}
