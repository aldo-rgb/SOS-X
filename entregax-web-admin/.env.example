# URL del backend al que apunta el frontend (en dev: localhost; en prod: Railway).
# Si está vacía, el frontend asume http://localhost:3001
VITE_API_URL=http://localhost:3001

# URL pública del backend usada SOLO para mostrar URLs de webhooks que deben ser
# accesibles desde Internet (Facturama, Openpay, etc.).
# Si está vacía, en dev cae al backend público de producción configurado en el código.
VITE_PUBLIC_BACKEND_URL=https://sos-x-production.up.railway.app
