{
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/privacy-policy",
      "destination": "https://api.entregax.app/legal/privacy-policy"
    },
    {
      "source": "/eliminar-cuenta",
      "destination": "https://api.entregax.app/eliminar-cuenta"
    },
    {
      "source": "/account-deletion",
      "destination": "https://api.entregax.app/account-deletion"
    },
    {
      "source": "/api/external/:path*",
      "destination": "https://api.entregax.app/api/external/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
